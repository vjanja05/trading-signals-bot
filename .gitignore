# Create .gitignore file
@"
# Python
__pycache__/
*.pyc
venv/
env/
ENV/

# Environment files
.env
.streamlit/secrets.toml

# Payment proofs
payment_proofs/
*.png
*.jpg
*.jpeg
*.txt

# IDE
.vscode/
.idea/

# Streamlit
.streamlit/

# Git
*.log
.DS_Store
"@ | Out-File -FilePath .gitignore -Encoding utf8